# CostPilot AI — environment variables
# Copy this file to .env and fill in ONE of the API keys below.
# The server tries Claude first, then Gemini, then falls back to local optimizer.

# ── Option A: Anthropic Claude (paid, ~$0.003/plan) ──────────────────────────
# Get key at: console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Option B: Google Gemini (FREE, 15 req/min, 1M tokens/day) ────────────────
# Get key at: aistudio.google.com → Get API key  (no credit card needed)
# Add up to 3 keys from different Google accounts to multiply the daily quota.
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
# GEMINI_API_KEY_2=YOUR_SECOND_KEY_HERE
# GEMINI_API_KEY_3=YOUR_THIRD_KEY_HERE

# ── Optional overrides ────────────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.0-flash
# PORT=4173
